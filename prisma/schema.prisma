generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Subject {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(100)
  slug      String     @unique @db.VarChar(100)
  icon      String?    @db.VarChar(50)
  color     String?    @db.VarChar(20)
  order     Int        @default(0)
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")
  resources Resource[]
  units     Unit[]

  @@map("subjects")
}

model Unit {
  id        Int        @id @default(autoincrement())
  subjectId Int        @map("subject_id")
  name      String     @db.VarChar(200)
  code      String?    @db.VarChar(50)
  course    String?    @db.VarChar(100)
  order     Int        @default(0)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  resources Resource[]

  @@map("units")
}

model Resource {
  id            Int      @id @default(autoincrement())
  subjectId     Int      @map("subject_id")
  unitId        Int?     @map("unit_id")
  title         String   @db.VarChar(255)
  description   String?  @db.Text
  activityType  String?  @db.VarChar(100) @map("activity_type")
  author        String?  @db.VarChar(150)
  imageUrl      String?  @db.Text @map("image_url")
  linkUrl       String?  @db.Text @map("link_url")
  course        String?  @db.VarChar(100)
  oaCode        String?  @db.VarChar(50) @map("oa_code")
  oaDescription String?  @db.Text @map("oa_description")
  order         Int      @default(0)
  isActive      Boolean  @default(true) @map("is_active")
  views         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  subject       Subject  @relation(fields: [subjectId], references: [id])
  unit          Unit?    @relation(fields: [unitId], references: [id])

  @@map("resources")
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(150)
  password  String   @db.VarChar(255)
  name      String?  @db.VarChar(150)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model Suggestion {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(255)
  description  String?  @db.Text
  linkUrl      String?  @db.Text @map("link_url")
  imageUrl     String?  @db.Text @map("image_url")
  teacherName  String?  @db.VarChar(150) @map("teacher_name")
  course       String?  @db.VarChar(100)
  activityType String?  @db.VarChar(100) @map("activity_type")
  subjectName  String?  @db.VarChar(100) @map("subject_name")
  subjectId    Int?     @map("subject_id")
  notes        String?  @db.Text
  status       String   @default("pending") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("suggestions")
}

model Slide {
  id         Int      @id @default(autoincrement())
  title      String   @db.VarChar(255)
  subtitle   String?  @db.VarChar(255)
  imageUrl   String?  @db.Text @map("image_url")
  linkUrl    String?  @db.Text @map("link_url")
  buttonText String?  @db.VarChar(100) @map("button_text")
  order      Int      @default(0)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("slides")
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model Course {
  id        Int     @id @default(autoincrement())
  name      String  @unique @db.VarChar(100)
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  @@map("courses")
}

model ActivityType {
  id       Int     @id @default(autoincrement())
  name     String  @unique @db.VarChar(100)
  isActive Boolean @default(true) @map("is_active")

  @@map("activity_types")
}
